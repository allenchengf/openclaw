# ════════════════════════════════════════════════════════════════════
# openclaw-Taiwan 部署設定範本
#
# 給第一次使用的同學：
#   1) cp .env.example .env
#   2) 只需填好下方【必填】三項
#   3) make install        ← 一鍵安裝（其餘有預設值，token/URL 會自動處理）
#
# 重要：值的右側「不要」加行內註解（# ...），註解請獨立成行。
#       Makefile include 會把行內註解前的空白併入變數值而造成錯誤。
# .env 已被 .gitignore 忽略，請勿提交。
# ════════════════════════════════════════════════════════════════════

# ─────────────────────────── 【必填】 ────────────────────────────────
# 你的 GCP 專案 ID（需已啟用計費）
GCP_PROJECT_ID=your-project-id
# 部署用的 gcloud 帳號
GCP_ACCOUNT=you@example.com
# Gemini API Key：https://aistudio.google.com/apikey
# 文字有免費額度；圖片生成(Nano Banana)需有圖片配額，建議用綁定計費專案的標準 AIza 金鑰。
GEMINI_API_KEY=your-gemini-api-key

# ─────────────────────────── 【選填，有預設值】 ──────────────────────
# 區域（台灣）
GCP_REGION=asia-east1
# Artifact Registry 庫名
AR_REPO_NAME=clawdbot-repo
# Cloud Run 服務名
SERVICE_NAME=clawdbot
# 映像標籤
IMAGE_TAG=v1
# npm openclaw 版本
OPENCLAW_VERSION=2026.6.1
# 1=常駐(減少冷啟動)；0=縮到零省費
MIN_INSTANCES=1
MEMORY=2Gi
CPU=1
OPENCLAW_MODEL=google/gemini-2.5-flash
# 記憶 embedding provider：none=關鍵字記憶(免金鑰、最穩，推薦)；gemini=語意記憶(需向量表)
OPENCLAW_MEMORY_PROVIDER=none
# 時區（AI 提示中的現在時間）
OPENCLAW_TIMEZONE=Asia/Taipei

# ─────────────── 【GCE VM 部署（make vm-deploy），記憶持久化】 ──────────
# Cloud Run 為無狀態，記憶不跨重啟保留；需持久記憶請改用 GCE VM（持久磁碟掛載 ~/.openclaw）。
GCE_ZONE=asia-east1-b
GCE_VM_NAME=clawdbot-vm
GCE_MACHINE_TYPE=e2-small
GCE_DATA_DISK_SIZE=10GB

# ─────────────────────── 【自動處理，通常免填】 ─────────────────────
# 留空時 `make install` 會自動：gen-token 產生 token、refresh-url 取得實際 URL。
# 64 字元 hex；Dashboard/CLI 連線用
OPENCLAW_GATEWAY_TOKEN=
# 對外 URL（control UI allowedOrigins / Google Chat audience）
OPENCLAW_PUBLIC_URL=

# ─────────────────────────── 【頻道，選填】 ─────────────────────────
# 是否啟用 Google Chat 頻道
GOOGLECHAT_ENABLED=true
# Google Chat Service Account 驗證為進階手動步驟（見 README「頻道設定」）：
# 將 SA JSON 存入 Secret 並掛載到 /secrets/google-chat-sa/key.json，容器會自動偵測。
# LINE OA：兩者皆填才會啟用 LINE 頻道
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
